# Copy to .env and fill in your Supabase project values.
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Web Push (VAPID) ──
# Generate a key pair: npm run generate-vapid-keys
# Paste the public key here. Set the private key + subject as
# Supabase Edge Function secrets (VAPID_PRIVATE_KEY, VAPID_SUBJECT).
PUBLIC_VAPID_KEY=
